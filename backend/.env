# Environment variables for local running fallback
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/typeahead
REDIS_NODES=redis-node-1=redis://localhost:6381/1,redis-node-2=redis://localhost:6382/2,redis-node-3=redis://localhost:6383/3
BATCH_FLUSH_INTERVAL=30
BATCH_MAX_SIZE=100
TRENDING_RECALC_INTERVAL=60
DATASET_SIZE=100000
